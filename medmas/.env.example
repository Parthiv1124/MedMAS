# DeepInfra
DEEPINFRA_API_KEY=di-...
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# Google Translate (for deep-translator fallback)
GOOGLE_TRANSLATE_API_KEY=...

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Google Maps (for reverse geocoding / auto-location)
GOOGLE_MAPS_API_KEY=AIza...

# App settings
DOCTORS_CSV_PATH=data/doctors.csv
LAB_RANGES_PATH=data/lab_ranges.json
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-cloud-api-key
QDRANT_COLLECTION=medmas_medical_kb
MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SPEECH_TO_TEXT_MODEL=openai/whisper-large-v3
